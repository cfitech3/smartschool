# ============================================================
# SmartSchool ERP -- Variables d'environnement
# ============================================================
# Copiez ce fichier en .env et remplissez les valeurs.
# Le fichier .env NE DOIT JAMAIS etre commite dans Git.
# Ajoutez ".env" a votre .gitignore.
# ============================================================

# -- Mode d'execution -----------------------------------------
# True = developpement (debug active, logs detailles)
# False = production (securite renforcee, pas de debug)
DEBUG=True

# -- Cle secrete ----------------------------------------------
# OBLIGATOIRE en production. Generez-en une avec :
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=remplacez-par-une-vraie-cle-secrete-generee-par-django

# -- Hotes autorises ------------------------------------------
# OBLIGATOIRE en production. Noms de domaine separes par des virgules.
# Exemple : ALLOWED_HOSTS=monecole.ml,www.monecole.ml,CFITECH.pythonanywhere.com
ALLOWED_HOSTS=localhost,127.0.0.1

# -- Base de donnees PostgreSQL (recommande en production) ----
# Laissez vide pour utiliser SQLite (developpement uniquement).
# Format : postgresql://utilisateur:motdepasse@hote:5432/nom_base
# Exemple : DATABASE_URL=postgresql://smartschool:motdepasse@localhost:5432/smartschool_db
DATABASE_URL=
